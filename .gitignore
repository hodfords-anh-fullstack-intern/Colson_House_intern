# Root gitignore to ensure secrets and binaries are never committed
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.example.local

# IDEs and editors
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS files
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Node / Package managers
node_modules/
jspm_packages/
.npm
.eslintcache
.stylelintcache
.parcel-cache
.next
.nuxt
dist/
tmp/
out/

# Backend / Composer
vendor/
.phpunit.result.cache
.phpunit.cache/
bootstrap/cache/
storage/*.key
storage/framework/cache/data/*
storage/framework/sessions/*
storage/framework/views/*
storage/framework/testing/*

# Database
/*.db
/*.sqlite
database/*.sqlite
database/*.db
